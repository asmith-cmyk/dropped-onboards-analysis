# Salesforce API auth. Use either username/password/security token or session/instance URL.
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login
SALESFORCE_INSTANCE_URL=
SALESFORCE_SESSION_ID=
SALESFORCE_API_VERSION=v60.0
SALESFORCE_DROPPED_REPORT_ID=00OQQ000007tl772AA
SALESFORCE_RETURNING_REPORT_ID=00OQQ000007tlAL2AY

# Zendesk Support API auth. Optional; empty credentials produce an empty enrichment file.
ZENDESK_SUBDOMAIN=raptive
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_SEARCH_QUERY=type:ticket tags:onboarding created>=2025-01-01
ZENDESK_EXPORT_CSV=

# Slack API auth. Optional; empty credentials produce an empty enrichment file.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_NAMES=onboarding-creatorgrowth,salesloft-meetings
SLACK_START_DATE=2025-01-01

# AI cancellation reason normalization. Rules are used automatically if no key is present.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
USE_OPENAI_CLASSIFICATION=true

